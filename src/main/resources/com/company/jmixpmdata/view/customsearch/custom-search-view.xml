<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://customSearchView.title">
    <data>
        <collection id="customersDc"
                    class="com.company.jmixpmdata.entity.Customer">
            <fetchPlan extends="_base"/>
            <loader id="customersDl">
                <query>
                    <![CDATA[select e from Customer e]]>
                    <condition>
                        <and>
                            <c:jpql>
                                <c:where>e.firstName like :component_customerFirstNameField</c:where>
                            </c:jpql>
                        </and>
                    </condition>
                </query>
            </loader>
        </collection>
        <collection id="ordersDc"
                    class="com.company.jmixpmdata.entity.Order">
            <fetchPlan extends="_base">
                <property name="customer" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="ordersDl">
                <query>
                    <![CDATA[
                select e from Order_ e where e.customer = :container_customersDc
                ]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="false"/>
    </facets>
    <layout>
        <hbox id="tablesBox" width="100%" height="100%">
            <vbox height="100%"
                  width="100%"
                  spacing="true"
                  expand="customersDataGrid">
                <textField id="customerFirstNameField"/>
                <dataGrid id="customersDataGrid"
                          dataContainer="customersDc"
                          minHeight="20em"
                          width="100%">
                    <columns>
                        <column property="firstName"/>
                        <column property="lastName"/>
                        <column property="email"/>
                    </columns>
                </dataGrid>
            </vbox>
            <dataGrid id="ordersDataGrid"
                      dataContainer="ordersDc"
                      minHeight="20em"
                      height="100%"
                      width="100%">
                <columns>
                    <column property="orderName"/>
                    <column property="customer"/>
                    <column property="date"/>
                </columns>
            </dataGrid>
        </hbox>
    </layout>
</view>