<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://userProjectsView.title">
    <data>
        <collection id="projectsDc" class="com.company.jmixpmdata.entity.Project">
            <fetchPlan extends="_base">
                <property name="manager" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="projectsDl" readOnly="true">
                <query>
                    select e from Project e where
                        (select u from User u where u = :user) MEMBER OF e.participants
                        or e.manager = :user
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <layout>
        <dataGrid id="projectsDataGrid" dataContainer="projectsDc" minWidth="100px" width="100%">
            <actions/>
            <columns>
                <column property="name"/>
                <column property="startDate"/>
                <column property="endDate"/>
                <column property="status"/>
                <column property="manager"/>
            </columns>
        </dataGrid>
    </layout>
</view>